{{!
    @template mod_oucontent/export_all_item

    Classes required for JS:

    Data attibutes required for JS:

    Context variables required for this template:

    Example context (json):
    {
        "shortname": "X123-24J",
        "hidden": false,
        "inrecyclebin": false,
        "lastpublished": 1234567890,
        "lastpublishedtime": "2020-01-01T00:00:00+08:00",
        "size": "4.3 MB",
        "sizebytes": 1234,
        "downloadurl": "https://example.org/",
        "haspresentations": false,
        "presentations": [],
        "hasawards": false,
        "awards": []
    }
}}
<li>
    <a href="{{downloadurl}}"
        data-shortname="{{shortname}}"
        data-lastpublished="{{lastpublishedtime}}"
        data-sizebytes="{{sizebytes}}"
        {{#haspresentations}}data-presentations="{{#presentations}}{{modulepres}} {{/presentations}}"{{/haspresentations}}
        {{#hasawards}}data-awards="{{#awards}}{{awardcode}} {{/awards}}"{{/hasawards}}
        {{#hidden}}data-hidden="true"{{/hidden}}
        {{#inrecyclebin}}data-inrecyclebin="true"{{/inrecyclebin}}
    >
        <span>{{shortname}}</span>
        <span>({{size}})</span>
    </a>
    <div class="oucontent-lastpublished">
        {{#userdate}}{{lastpublished}}, {{#str}}strftimedatetimeshort, langconfig{{/str}}{{/userdate}}
    </div>
    {{#haspresentations}}
        <ul class="oucontent-presentations">
            {{#presentations}}
                <li>{{modulepres}}</li>
            {{/presentations}}
        </ul>
    {{/haspresentations}}
    {{#hasawards}}
        <ul class="oucontent-awards">
            {{#awards}}
                <li>{{awardcode}}</li>
            {{/awards}}
        </ul>
    {{/hasawards}}
    <div class="oucontent-details">
        {{#hidden}}
            <span>{{#str}}hiddenfromstudents{{/str}}.</span>
        {{/hidden}}
        {{#inrecyclebin}}
            <span>{{#str}}exportallinrecyclebin, mod_oucontent{{/str}}.</span>
        {{/inrecyclebin}}
    </div>
</li>
